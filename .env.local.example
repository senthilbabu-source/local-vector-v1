# ============================================================
# LocalVector.ai — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # Server-only — never expose to client

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Perplexity ===
PERPLEXITY_API_KEY=pplx-...

# === Google Places ===
GOOGLE_PLACES_API_KEY=AIza...

# === Google OAuth (Google Business Profile + user sign-in) ===
# From Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs must include: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# === AI Providers ===
# Anthropic API key for Claude-powered features (Truth Audit, content audit)
# From: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Google AI API key for Gemini/Search Grounding features (SOV multi-engine)
# From: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy-your-key-here

# xAI (Grok) — required for Grok SOV engine (agency plan)
XAI_API_KEY=xai-...

# You.com — required for You.com SOV engine (agency plan)
YOUCOM_API_KEY=uc-...

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_AGENCY_SEAT=price_...
# Optional: Programmatic portal config (run scripts/setup-stripe-portal.ts to generate)
STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# === Resend ===
RESEND_API_KEY=re_...

# === Upstash Redis / Vercel KV (Rate Limiting) ===
# Primary keys (preferred by lib/redis.ts):
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=AX...
# Fallback keys (Vercel KV-compatible, also accepted):
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# === App Config ===
NEXT_PUBLIC_APP_URL=https://app.localvector.ai
NEXT_PUBLIC_MENU_URL=https://menu.localvector.ai
NEXT_PUBLIC_MARKETING_URL=https://localvector.ai

# === AEO Configuration ===
NEXT_PUBLIC_AEO_REPORT_URL=https://app.localvector.ai/report

# === MCP Server Auth ===
MCP_API_KEY=                         # Bearer token for MCP endpoint. Fails closed when absent.

# === Inngest (Job Queue) ===
INNGEST_EVENT_KEY=                    # Production: from Inngest Cloud dashboard
INNGEST_SIGNING_KEY=                  # Production: from Inngest Cloud dashboard

# === Sentry (Sprint 26A) ===
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=localvector
SENTRY_PROJECT=localvector-nextjs

# ═══════════════════════════════════════════════════════════════
# CRON SECURITY
# ═══════════════════════════════════════════════════════════════

# Secret used to authenticate Vercel cron invocations.
# Vercel sends: Authorization: Bearer <CRON_SECRET>
# Generate a strong random value: openssl rand -hex 32
# Must also be set in Vercel dashboard → Project Settings → Environment Variables
CRON_SECRET=your-cron-secret-here

# ═══════════════════════════════════════════════════════════════
# CRON KILL SWITCHES
# Set to "true" to disable a specific cron without unregistering it.
# Useful for pausing expensive AI operations during budget reviews.
# Default: unset or "false" (cron runs normally)
# ═══════════════════════════════════════════════════════════════

STOP_AUDIT_CRON=false
STOP_SOV_CRON=false
STOP_CITATION_CRON=false
STOP_DIGEST_CRON=false
STOP_PLACES_REFRESH_CRON=false
STOP_CONTENT_AUDIT_CRON=false
STOP_TOKEN_REFRESH_CRON=false
STOP_CORRECTION_FOLLOWUP_CRON=false
STOP_BENCHMARK_CRON=false
STOP_NAP_SYNC_CRON=false
STOP_SCHEMA_DRIFT_CRON=false
STOP_AUTHORITY_CRON=false
STOP_REVIEW_SYNC_CRON=false
STOP_AUTOPILOT_CRON=false
STOP_VAIO_CRON=false
STOP_DATA_HEALTH_CRON=false
STOP_FAQ_CRON=false
STOP_DATA_CLEANUP_CRON=false
STOP_HIJACK_DETECTION_CRON=false
STOP_DEGRADATION_CHECK_CRON=false
STOP_CORRECTION_BENCHMARKS_CRON=false
STOP_AI_SHOPPER_CRON=false
STOP_COMPETITOR_VULNERABILITY_CRON=false
STOP_MONTHLY_REPORT_CRON=false
STOP_AI_OVERVIEWS_CRON=false
STOP_GOOGLE_REFRESH=false   # Set to 'true' to instantly halt Google API spending

# ═══════════════════════════════════════════════════════════════
# ADMIN DASHBOARD
# ═══════════════════════════════════════════════════════════════

# Comma-separated list of emails allowed to access /admin routes.
# Case-insensitive, whitespace-trimmed. Non-admins redirect to /dashboard.
ADMIN_EMAILS=admin@localvector.ai

# ═══════════════════════════════════════════════════════════════
# LISTINGS VERIFICATION (Sprint L)
# ═══════════════════════════════════════════════════════════════

# Yelp Fusion API key for verifying business listings on Yelp.
# From: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Bing Maps API key for verifying business listings on Bing Places.
# From: Azure Portal → Bing Maps → Keys
BING_MAPS_KEY=

# ═══════════════════════════════════════════════════════════════
# NAP SYNC ENGINE (Sprint 105)
# ═══════════════════════════════════════════════════════════════

# Yelp Fusion API key for NAP sync adapter (phone, name, address checks).
# From: https://www.yelp.com/developers/v3/manage_app
YELP_FUSION_API_KEY=

# Bing Search API key for NAP sync adapter (local entity search).
# From: Azure Portal → Bing Search → Keys
BING_SEARCH_API_KEY=

# Apple Maps Server-to-Server auth (MapKit JS).
# From: Apple Developer → Certificates, Identifiers & Profiles → Keys
APPLE_MAPS_PRIVATE_KEY=
APPLE_MAPS_KEY_ID=
APPLE_MAPS_TEAM_ID=

# ═══════════════════════════════════════════════════════════════
# SCHEMA EXPANSION (Sprint 106)
# ═══════════════════════════════════════════════════════════════

# IndexNow API key for rapid re-indexing after schema publish.
# Generate at: https://www.indexnow.org/
INDEXNOW_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ALERTS (Sprint 118)
# ═══════════════════════════════════════════════════════════════

# Slack incoming webhook URL for operational alerts (SOV drops, etc.).
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# SOV score drop threshold for Slack alerts. Alert fires when delta <= -threshold.
# Default: 5
SLACK_SOV_DROP_THRESHOLD=5

# ═══════════════════════════════════════════════════════════════
# CACHE REVALIDATION (Sprint 118)
# ═══════════════════════════════════════════════════════════════

# Secret for server-to-server on-demand cache revalidation of /m/[slug] pages.
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=

# ═══════════════════════════════════════════════════════════════
# APPLE BUSINESS CONNECT (Sprint 130)
# ═══════════════════════════════════════════════════════════════

# Apple Business Connect API credentials (ES256 JWT auth).
# From: https://businessconnect.apple.com → API Settings
APPLE_BC_CLIENT_ID=
APPLE_BC_CLIENT_SECRET=
APPLE_BC_PRIVATE_KEY=

# Kill switch for Apple BC nightly sync cron.
APPLE_BC_CRON_DISABLED=false

# Kill switch for Agent-SEO weekly audit cron.
AGENT_SEO_CRON_DISABLED=false

# ═══════════════════════════════════════════════════════════════
# PLAYBOOKS & INTENT DISCOVERY (Sprints 134-135)
# ═══════════════════════════════════════════════════════════════

# Kill switch for per-engine playbook generation cron (Monday 9 AM UTC).
PLAYBOOK_CRON_DISABLED=false

# Kill switch for conversational intent discovery cron (Thursday 10 AM UTC).
INTENT_CRON_DISABLED=false

# ═══════════════════════════════════════════════════════════════
# VERCEL (P7-FIX-32)
# ═══════════════════════════════════════════════════════════════

# Auto-set by Vercel at build time. Used by /api/health for version reporting.
# Do NOT set manually — Vercel injects the Git commit SHA automatically.
VERCEL_GIT_COMMIT_SHA=
